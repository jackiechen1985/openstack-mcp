{
  "name": "openstack-mcp",
  "version": "1.0.0",
  "description": "OpenStack MCP Server implementation",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "bin": {
    "openstack-mcp": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "tsx src/index.ts",
    "debug": "npm run build && npx @modelcontextprotocol/inspector node ./dist/index.cjs --log-file ./openstack-mcp.log --log-level debug",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mcp",
    "openstack",
    "modelcontextprotocol"
  ],
  "author": "Chen Xiaobo",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/commander": "^2.12.0",
    "axios": "^1.15.0",
    "mcp-http-server": "^1.2.4",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "run-script-os": "^1.1.6",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
