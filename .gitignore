# ==========================================
# 1. 依赖目录
# ==========================================
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ==========================================
# 2. 构建产物与编译输出
# ==========================================
# TypeScript 编译输出目录 (通常在 tsconfig.json 中配置为 outDir)
dist/
build/
lib/
out/

# 增量编译缓存文件 (tsconfig.json 开启 incremental 时生成)
*.tsbuildinfo

# ==========================================
# 3. 编辑器与 IDE 配置
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store

# ==========================================
# 4. 环境变量与敏感信息
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# ==========================================
# 5. 日志文件
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ==========================================
# 6. 自动生成的类型声明 (视情况而定)
# ==========================================
# 如果是 unocss, vite-plugin-components 等自动生成的
@types/auto-imports.d.ts
@types/components.d.ts